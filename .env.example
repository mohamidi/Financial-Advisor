# Copy to .env and fill in. Never commit .env.

# Anthropic Console -> API Keys
ANTHROPIC_API_KEY=

# Supabase project -> Project Settings -> Database -> Connection string (use the "URI" / pooled one)
# sslmode=require makes encryption mandatory (psycopg's default "prefer" allows silent
# plaintext fallback if the server claims SSL is unavailable)
DATABASE_URL=postgresql+psycopg://postgres:[password]@[host]:5432/postgres?sslmode=require

# Supabase project -> Project Settings -> API
SUPABASE_URL=https://[project-ref].supabase.co
# Project Settings -> API Keys -> publishable key (sb_publishable_...). Low-privilege, safe to
# expose to a frontend; frontend uses this later, local test scripts use it now to call the
# Auth API (e.g. signing up a test user).
SUPABASE_PUBLISHABLE_KEY=
# Project Settings -> API Keys -> secret key (sb_secret_...). High-privilege, backend-only, bypasses
# RLS. Used for admin-style Auth operations (e.g. scripts/create_demo_user.py), not for regular
# per-user data queries (those use the Data API with that user's own JWT instead).
SUPABASE_SECRET_KEY=

# A persistent, real Supabase Auth identity used for seed/demo data - not the project owner's
# real account. Created by scripts/create_demo_user.py.
DEMO_USER_ID=

# Day 8 cost/abuse controls (optional - sensible defaults in app/config.py). Uncomment to override.
# Per-user daily token cap (input+output); over it, /chat returns 429 before any Claude call.
# DAILY_TOKEN_BUDGET_PER_USER=200000
# Per-user messages/hour cap; over it, /chat returns 429 + Retry-After before any Claude call.
# MAX_MESSAGES_PER_HOUR_PER_USER=30
# CORS origin allowlist (comma-separated). Empty = same-origin only (current setup, since the API
# serves the SPA). Set to the frontend's origin(s) if it's ever hosted separately - never "*".
# CORS_ALLOWED_ORIGINS=https://app.example.com

# Phase 2 (Plaid) - leave blank until that phase
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Symmetric key used to encrypt Plaid access tokens at rest (Phase 2)
PLAID_TOKEN_ENCRYPTION_KEY=
