# Copy to .env and fill in. Never commit .env.

# Anthropic Console -> API Keys
ANTHROPIC_API_KEY=

# Supabase project -> Project Settings -> Database -> Connection string (use the "URI" / pooled one)
DATABASE_URL=postgresql+psycopg://postgres:[password]@[host]:5432/postgres

# Supabase project -> Project Settings -> API
SUPABASE_URL=https://[project-ref].supabase.co
# Project Settings -> API -> JWT Settings -> JWT Secret (used to verify tokens Supabase issues)
SUPABASE_JWT_SECRET=

# Phase 2 (Plaid) - leave blank until that phase
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Symmetric key used to encrypt Plaid access tokens at rest (Phase 2)
PLAID_TOKEN_ENCRYPTION_KEY=
