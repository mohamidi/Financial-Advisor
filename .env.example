# Copy to .env and fill in. Never commit .env.

# Anthropic Console -> API Keys
ANTHROPIC_API_KEY=

# SQLite file path (relative to repo root)
DATABASE_PATH=data/app.db

# Flip to true once served over HTTPS (Phase 3 hosting)
COOKIE_SECURE=false

# Phase 2 (Plaid) - leave blank until that phase
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Symmetric key used to encrypt Plaid access tokens at rest (Phase 2)
PLAID_TOKEN_ENCRYPTION_KEY=
